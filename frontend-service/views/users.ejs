<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Define all functions immediately in head to avoid timing issues -->
    <script>
        // Global variables
        let usersData = [];
        let originalUsersData = [];
        let userChart = null;

        // Define toggleUserView function immediately
        window.toggleUserView = function(viewType) {
            console.log('🔄 Toggling view to:', viewType);
            const gridContainer = document.getElementById('usersGridContainer');
            const chartContainer = document.getElementById('userChartContainer');

            if (viewType === 'grid') {
                if (chartContainer) chartContainer.style.display = 'none';
                if (gridContainer) gridContainer.style.display = 'block';
            } else if (viewType === 'chart') {
                if (gridContainer) gridContainer.style.display = 'none';
                if (chartContainer) chartContainer.style.display = 'block';

                // Initialize or update chart
                setTimeout(() => {
                    if (!userChart) {
                        initializeUserChart();
                    } else {
                        updateUserChart();
                    }
                }, 100);
            }
        };

        // Define sortUsers function immediately
        window.sortUsers = function() {
            const sortSelect = document.getElementById('sortUsers');
            if (!sortSelect || !usersData) return;
            
            const sortBy = sortSelect.value;
            let sortedUsers = [...usersData];

            switch (sortBy) {
                case 'votes-desc':
                    sortedUsers.sort((a, b) => (b.voteCount || 0) - (a.voteCount || 0));
                    break;
                case 'votes-asc':
                    sortedUsers.sort((a, b) => (a.voteCount || 0) - (b.voteCount || 0));
                    break;
                case 'name-asc':
                    sortedUsers.sort((a, b) => (a.name || a.shortname || '').localeCompare(b.name || b.shortname || ''));
                    break;
                case 'name-desc':
                    sortedUsers.sort((a, b) => (b.name || b.shortname || '').localeCompare(a.name || a.shortname || ''));
                    break;
                default:
                    sortedUsers.sort((a, b) => (b.voteCount || 0) - (a.voteCount || 0));
            }

            usersData = sortedUsers;
            renderUserGrid(sortedUsers);

            // Update chart if visible
            if (document.getElementById('userChartContainer')?.style.display !== 'none') {
                updateUserChart();
            }
        };

        // Define filterUsers function immediately
        window.filterUsers = function() {
            const filterInput = document.getElementById('filterUsers');
            if (!filterInput || !originalUsersData) return;
            
            const filterText = filterInput.value.toLowerCase();
            let filteredUsers = originalUsersData;

            if (filterText) {
                filteredUsers = originalUsersData.filter(user =>
                    (user.name || '').toLowerCase().includes(filterText) ||
                    (user.shortname || '').toLowerCase().includes(filterText) ||
                    (user.email || '').toLowerCase().includes(filterText) ||
                    (user.title || '').toLowerCase().includes(filterText) ||
                    (user.department || '').toLowerCase().includes(filterText)
                );
            }

            usersData = filteredUsers;
            window.sortUsers();
        };

        // Make functions available without window prefix
        toggleUserView = window.toggleUserView;
        sortUsers = window.sortUsers;
        filterUsers = window.filterUsers;

        console.log('✅ Functions defined in head');
    </script>

    <style>
        .user-card {
            transition: transform 0.2s;
            border: 1px solid #dee2e6;
        }

        .user-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .user-avatar {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 1.2rem;
        }

        .stats-badge {
            font-size: 0.9rem;
        }

        .vote-count {
            color: #0d6efd;
            font-weight: bold;
        }

        .products-voted {
            color: #198754;
        }

        .last-vote {
            color: #6c757d;
            font-size: 0.8rem;
        }

        .top-voter {
            border-left: 4px solid #ffc107;
        }

        .navigation-tabs {
            margin-bottom: 2rem;
        }

        .service-status {
            font-size: 0.9rem;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container py-4">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-12">
                <h1 class="text-center mb-3">
                    <i class="fas fa-users text-primary"></i>
                    System Users
                </h1>

                <!-- Navigation Tabs -->
                <div class="navigation-tabs">
                    <ul class="nav nav-pills justify-content-center">
                        <li class="nav-item">
                            <a class="nav-link" href="/">
                                <i class="fas fa-vote-yea"></i> Products & Voting
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link active" href="/users">
                                <i class="fas fa-users"></i> Users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/register">
                                <i class="fas fa-user-plus"></i> Register
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Service Status Alert -->
                <% if (userServiceError) { %>
                    <div class="alert alert-warning text-center service-status">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>User Service Unavailable:</strong>
                        <%= userServiceError %>
                        <br>
                        <small class="text-muted">Displaying users from direct database connection</small>
                    </div>
                <% } else { %>
                    <div class="alert alert-success text-center service-status">
                        <i class="fas fa-check-circle"></i>
                        Connected to User Service successfully
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Stats Summary -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title">Total Users</h5>
                        <h2 class="text-primary"><%= totalUsers %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title">Active Users</h5>
                        <h2 class="text-success"><%= activeUsers %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title">Users Who Voted</h5>
                        <h2 class="text-info"><%= totalVoters %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title">Participation Rate</h5>
                        <h2 class="text-warning">
                            <%= totalUsers > 0 ? Math.round((totalVoters / totalUsers) * 100) : 0 %>%
                        </h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sorting and Visualization Controls -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-4">
                                <label for="sortUsers" class="form-label">
                                    <i class="fas fa-sort"></i> Sort Users By:
                                </label>
                                <select class="form-select" id="sortUsers" onchange="sortUsers()">
                                    <option value="votes-desc">Most Votes First</option>
                                    <option value="votes-asc">Least Votes First</option>
                                    <option value="name-asc">Name (A-Z)</option>
                                    <option value="name-desc">Name (Z-A)</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">
                                    <i class="fas fa-chart-bar"></i> Visualization:
                                </label>
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="userViewMode" id="userGridView" checked
                                        onchange="toggleUserView('grid')">
                                    <label class="btn btn-outline-primary" for="userGridView">
                                        <i class="fas fa-th"></i> Grid
                                    </label>
                                    <input type="radio" class="btn-check" name="userViewMode" id="userChartView"
                                        onchange="toggleUserView('chart')">
                                    <label class="btn btn-outline-primary" for="userChartView">
                                        <i class="fas fa-chart-bar"></i> Chart
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">
                                    <i class="fas fa-filter"></i> Filter:
                                </label>
                                <input type="text" class="form-control" id="filterUsers" placeholder="Search users..."
                                    onkeyup="filterUsers()">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart View Container -->
        <div id="userChartContainer" class="row mb-4" style="display: none;">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="fas fa-chart-bar"></i> User Voting Statistics (Sorted by Vote Count)
                        </h5>
                    </div>
                    <div class="card-body" style="height: 400px;">
                        <canvas id="userChart" width="400" height="200"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Users Grid -->
        <div id="usersGridContainer" class="row">
            <% if (users.length > 0) { %>
                <% users.forEach((user, index) => { %>
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card user-card h-100 <%= user.voteCount > 0 && index < 3 ? 'top-voter' : '' %>">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar me-3">
                                        <%= (user.name || user.shortname || 'U').charAt(0).toUpperCase() %>
                                    </div>
                                    <div>
                                        <h6 class="mb-0">
                                            <%= user.name || user.shortname || 'Unknown User' %>
                                        </h6>
                                        <small class="text-muted">@<%= user.shortname || user.id || 'unknown' %></small>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <% if (user.voteCount > 0 && index < 3) { %>
                                        <span class="badge bg-warning">
                                            <i class="fas fa-trophy"></i> #<%= index + 1 %> Voter
                                        </span>
                                    <% } %>
                                    <div class="mt-1">
                                        <span class="badge <%= user.isActive ? 'bg-success' : 'bg-secondary' %>">
                                            <i class="fas <%= user.isActive ? 'fa-check-circle' : 'fa-pause-circle' %>"></i>
                                            <%= user.isActive ? 'Active' : 'Inactive' %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <% if (user.title) { %>
                                    <p class="text-muted mb-2">
                                        <i class="fas fa-briefcase"></i>
                                        <%= user.title %>
                                    </p>
                                <% } %>

                                <% if (user.email) { %>
                                    <p class="text-muted mb-2">
                                        <i class="fas fa-envelope"></i>
                                        <%= user.email %>
                                    </p>
                                <% } %>

                                <% if (user.department) { %>
                                    <p class="text-muted mb-2">
                                        <i class="fas fa-building"></i>
                                        <%= user.department %>
                                    </p>
                                <% } %>

                                <!-- Voting Statistics -->
                                <div class="row text-center mb-3">
                                    <div class="col-4">
                                        <div class="stats-badge">
                                            <div class="vote-count fw-bold">
                                                <%= user.voteCount || 0 %>
                                            </div>
                                            <small class="text-muted">Total Votes</small>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="stats-badge">
                                            <div class="products-voted fw-bold">
                                                <%= user.uniqueProductsVoted || 0 %>
                                            </div>
                                            <small class="text-muted">Products</small>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="stats-badge">
                                            <div class="text-info fw-bold">
                                                <%= user.uniqueProductsVoted > 0 ? 
                                                    Math.round(user.voteCount / user.uniqueProductsVoted * 10) / 10 : 0 %>
                                            </div>
                                            <small class="text-muted">Avg/Product</small>
                                        </div>
                                    </div>
                                </div>

                                <% if (user.lastVote) { %>
                                    <div class="last-vote text-center">
                                        <i class="fas fa-clock"></i>
                                        Last vote: <%= new Date(user.lastVote).toLocaleDateString() %>
                                    </div>
                                <% } else if (user.voteCount === 0) { %>
                                    <div class="last-vote text-center text-muted">
                                        <i class="fas fa-info-circle"></i>
                                        No votes yet
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12">
                    <div class="alert alert-info text-center">
                        <i class="fas fa-users"></i>
                        <h4>No Users Found</h4>
                        <p class="mb-0">No users are currently registered in the system.</p>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Initialize data when page loads
        document.addEventListener('DOMContentLoaded', function() {
            // Load user data
            usersData = <%- JSON.stringify(users) %>;
            originalUsersData = [...usersData];
            
            console.log('📊 User data loaded:', usersData.length, 'users');
            console.log('📊 Users with votes:', usersData.filter(u => (u.voteCount || 0) > 0).length);
            
            // Apply initial sorting by votes
            sortUsers();
        });

        // Initialize User Chart
        function initializeUserChart() {
            try {
                const canvas = document.getElementById('userChart');
                if (!canvas) {
                    console.error('❌ Chart canvas not found');
                    return;
                }

                const ctx = canvas.getContext('2d');
                if (!ctx) {
                    console.error('❌ Could not get canvas context');
                    return;
                }

                // Destroy existing chart if it exists
                if (userChart) {
                    userChart.destroy();
                }

                console.log('📊 Creating chart...');

                userChart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: [],
                        datasets: [{
                            label: 'Total Votes',
                            data: [],
                            backgroundColor: 'rgba(54, 162, 235, 0.8)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                title: {
                                    display: true,
                                    text: 'Vote Count'
                                }
                            }
                        },
                        plugins: {
                            title: {
                                display: true,
                                text: 'Top Users by Vote Count'
                            }
                        }
                    }
                });

                updateUserChart();
                console.log('✅ Chart initialized successfully');

            } catch (error) {
                console.error('❌ Error initializing chart:', error);
            }
        }

        // Update User Chart - ALWAYS sorts by vote count
        function updateUserChart() {
            if (!userChart) {
                console.log('📊 Chart not ready, initializing...');
                initializeUserChart();
                return;
            }

            console.log('📊 Updating chart with vote-sorted data');

            // ALWAYS sort by vote count for chart (descending)
            const sortedUsers = originalUsersData
                .filter(u => (u.voteCount || 0) > 0)
                .sort((a, b) => (b.voteCount || 0) - (a.voteCount || 0))
                .slice(0, 15);

            console.log('📊 Chart showing top', sortedUsers.length, 'users with votes');

            if (sortedUsers.length === 0) {
                userChart.data.labels = ['No voting activity'];
                userChart.data.datasets[0].data = [0];
            } else {
                userChart.data.labels = sortedUsers.map(u => {
                    const name = u.name || u.shortname || 'Unknown';
                    return name.length > 12 ? name.substring(0, 12) + '...' : name;
                });
                userChart.data.datasets[0].data = sortedUsers.map(u => u.voteCount || 0);
            }

            userChart.update();
            console.log('✅ Chart updated with vote-sorted data');
        }

        // Render User Grid
        function renderUserGrid(users) {
            const container = document.getElementById('usersGridContainer');
            if (!container) return;

            container.innerHTML = '';

            if (users.length === 0) {
                container.innerHTML = `
                    <div class="col-12">
                        <div class="alert alert-warning text-center">
                            <i class="fas fa-search"></i>
                            No users match your search criteria.
                        </div>
                    </div>
                `;
                return;
            }

            users.forEach((user, index) => {
                const userCard = `
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card user-card h-100 ${(user.voteCount || 0) > 0 && index < 3 ? 'top-voter' : ''}">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar me-3">
                                        ${(user.name || user.shortname || 'U').charAt(0).toUpperCase()}
                                    </div>
                                    <div>
                                        <h6 class="mb-0">${user.name || user.shortname || 'Unknown User'}</h6>
                                        <small class="text-muted">@${user.shortname || user.id || 'unknown'}</small>
                                    </div>
                                </div>
                                <div class="text-end">
                                    ${(user.voteCount || 0) > 0 && index < 3 ? `
                                        <span class="badge bg-warning">
                                            <i class="fas fa-trophy"></i> #${index + 1} Voter
                                        </span>
                                    ` : ''}
                                    <div class="mt-1">
                                        <span class="badge ${user.isActive ? 'bg-success' : 'bg-secondary'}">
                                            <i class="fas ${user.isActive ? 'fa-check-circle' : 'fa-pause-circle'}"></i>
                                            ${user.isActive ? 'Active' : 'Inactive'}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                ${user.title ? `<p class="text-muted mb-2"><i class="fas fa-briefcase"></i> ${user.title}</p>` : ''}
                                ${user.email ? `<p class="text-muted mb-2"><i class="fas fa-envelope"></i> ${user.email}</p>` : ''}
                                ${user.department ? `<p class="text-muted mb-2"><i class="fas fa-building"></i> ${user.department}</p>` : ''}
                                
                                <div class="row text-center mb-3">
                                    <div class="col-4">
                                        <div class="stats-badge">
                                            <div class="vote-count fw-bold">${user.voteCount || 0}</div>
                                            <small class="text-muted">Total Votes</small>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="stats-badge">
                                            <div class="products-voted fw-bold">${user.uniqueProductsVoted || 0}</div>
                                            <small class="text-muted">Products</small>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="stats-badge">
                                            <div class="text-info fw-bold">
                                                ${(user.uniqueProductsVoted || 0) > 0 ? 
                                                    Math.round((user.voteCount || 0) / (user.uniqueProductsVoted || 0) * 10) / 10 : 0}
                                            </div>
                                            <small class="text-muted">Avg/Product</small>
                                        </div>
                                    </div>
                                </div>
                                
                                ${user.lastVote ? `
                                    <div class="last-vote text-center">
                                        <i class="fas fa-clock"></i>
                                        Last vote: ${new Date(user.lastVote).toLocaleDateString()}
                                    </div>
                                ` : `
                                    <div class="last-vote text-center text-muted">
                                        <i class="fas fa-info-circle"></i>
                                        No votes yet
                                    </div>
                                `}
                            </div>
                        </div>
                    </div>
                `;
                container.innerHTML += userCard;
            });
        }
    </script>
</body>

</html>